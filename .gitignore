.gopath/

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below if you do not want to track this)
# vendor/

# Go workspace file
go.work

# Build artifacts
dist/
build/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Local config files
.env
.env.local
*.local   
